<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PhoneChallenge" parent="Theme.AppCompat.NoActionBar">
        <!-- Set the status bar to black to match the Compose theme -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

    <!-- Splash theme — shown during cold start via the SplashScreen API -->
    <style name="Theme.PhoneChallenge.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="postSplashScreenTheme">@style/Theme.PhoneChallenge</item>
    </style>

</resources>